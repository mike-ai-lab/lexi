rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isFileOwner() {
      // Files are owned by the project owner. This requires a get() which is expensive.
      // For simplicity in this prototype, we'll assume files have a userId field too,
      // or we'll check the parent project.
      return isAuthenticated() && (
        (resource != null && request.auth.uid == resource.data.userId) ||
        (request.resource != null && request.auth.uid == request.resource.data.userId)
      );
    }

    // ===============================================================
    // Projects
    // ===============================================================
    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    // ===============================================================
    // Files
    // ===============================================================
    match /files/{fileId} {
      allow read: if isFileOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isFileOwner() && request.resource.data.userId == resource.data.userId;
      allow delete: if isFileOwner();
    }

    // ===============================================================
    // File Versions
    // ===============================================================
    match /fileVersions/{versionId} {
      allow read: if isAuthenticated(); // Simplified for prototype
      allow create: if isAuthenticated();
    }
  }
}
