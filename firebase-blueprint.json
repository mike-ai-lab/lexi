{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A workspace project containing multiple files.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the project." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was created." },
        "userId": { "type": "string", "description": "The UID of the owner." }
      },
      "required": ["name", "createdAt", "userId"]
    },
    "File": {
      "title": "File",
      "description": "A document or code file within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "The ID of the parent project." },
        "name": { "type": "string", "description": "The filename." },
        "path": { "type": "string", "description": "The relative path within the project." },
        "type": { "type": "string", "description": "The file extension or type (md, js, etc.)." },
        "content": { "type": "string", "description": "The text content of the file." },
        "lastModified": { "type": "string", "format": "date-time", "description": "When the file was last updated." }
      },
      "required": ["projectId", "name", "path", "type", "content", "lastModified"]
    },
    "FileVersion": {
      "title": "FileVersion",
      "description": "A historical version of a file storing a semantic patch.",
      "type": "object",
      "properties": {
        "fileId": { "type": "string", "description": "The ID of the file." },
        "patch": { "type": "string", "description": "The JSON-encoded semantic patch." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When this version was created." },
        "summary": { "type": "string", "description": "AI-generated summary of the change." }
      },
      "required": ["fileId", "patch", "createdAt", "summary"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects."
    },
    "/files/{fileId}": {
      "schema": "File",
      "description": "Collection of files across all projects."
    },
    "/fileVersions/{versionId}": {
      "schema": "FileVersion",
      "description": "Collection of file version history."
    }
  }
}
